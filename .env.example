# Flask
SECRET_KEY=your-secret-key-here

# Initial admin bootstrap (optional, first run only).
# There is NO default password — leave DEFAULT_ADMIN_PASSWORD blank and no
# admin is auto-created (you can promote a user later via the DB/admin UI).
# To bootstrap the first admin, set a STRONG, UNIQUE password here; trivial
# values like "admin" are rejected.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# Database
DB_TYPE=sqlite
SQLITE_PATH=./dummy.db

# MySQL (production)
MYSQL_HOST=your-host.mysql.pythonanywhere-services.com
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=your-database-name

# Email — Mailgun
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=mail.yourdomain.com
MAILGUN_REGION=eu
SENDER_EMAIL=noreply@mail.yourdomain.com
SENDER_NAME=YourAppName

# Email — SMTP (backup, optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=True
# SMTP_USE_SSL=False
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Verification
TOKEN_EXPIRY_HOURS=48
UNVERIFIED_CLEANUP_DAYS=14
MAX_VERIFICATION_EMAILS_PER_DAY=3

# Off-site backup (Backblaze B2)
B2_KEY_ID=              # Application key ID from B2 console
B2_APPLICATION_KEY=     # Application key from B2 console
B2_BUCKET_NAME=         # Bucket name
OFFSITE_KEEP_COUNT=14   # Number of remote backups to retain
SLACK_WEBHOOK_URL=      # Optional: Slack Incoming Webhook URL for failure alerts
