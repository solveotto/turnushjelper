# Flask
SECRET_KEY=your-secret-key-here

# Database
DB_TYPE=sqlite
SQLITE_PATH=./dummy.db

# MySQL (production)
MYSQL_HOST=your-host.mysql.pythonanywhere-services.com
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=your-database-name

# Email — Mailgun
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=mail.yourdomain.com
MAILGUN_REGION=eu
SENDER_EMAIL=noreply@mail.yourdomain.com
SENDER_NAME=YourAppName

# Email — SMTP (backup, optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=True
# SMTP_USE_SSL=False
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Verification
TOKEN_EXPIRY_HOURS=48
UNVERIFIED_CLEANUP_DAYS=14
MAX_VERIFICATION_EMAILS_PER_DAY=3

# Off-site backup (offsite_backup.py)
HOME_BACKUP_HOST=         # IP or dynamic DNS hostname of home server
HOME_BACKUP_USER=         # SSH username on home server
HOME_BACKUP_PATH=         # Absolute path to backup dir, e.g. /home/youruser/turnushjelper-backups
HOME_BACKUP_SSH_KEY=      # Path to SSH private key on PythonAnywhere, e.g. /home/solveottooren/.ssh/backup_key
HOME_BACKUP_PORT=3125     # SSH port forwarded on your router
OFFSITE_KEEP_COUNT=14     # Number of remote backups to retain
