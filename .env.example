# Flask
SECRET_KEY=your-secret-key-here

# Werkzeug debugger for `python run.py`. Defaults to OFF in run.py — the
# debugger allows arbitrary code execution, so it must never come on by
# accident on a server. Keep this true for local development.
FLASK_DEBUG=true

# Initial admin bootstrap (optional, first run only).
# There is NO default password — leave DEFAULT_ADMIN_PASSWORD blank and no
# admin is auto-created (you can promote a user later via the DB/admin UI).
# To bootstrap the first admin, set a STRONG, UNIQUE password here; trivial
# values like "admin" are rejected.
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=

# Database
DB_TYPE=sqlite
SQLITE_PATH=./dummy.db

# Session cookie hardening (optional).
# SESSION_COOKIE_SECURE (the Secure flag) defaults ON when DB_TYPE=mysql
# (production, served over HTTPS) and OFF for sqlite dev over plain HTTP.
# Set explicitly if your setup differs (e.g. prod on a non-mysql DB behind
# HTTPS → True). SameSite defaults to Lax.
# SESSION_COOKIE_SECURE=True
# SESSION_COOKIE_SAMESITE=Lax

# Reverse proxy (production runs behind nginx).
# TRUSTED_PROXY_COUNT = number of proxy hops you control. The app then trusts
# that many X-Forwarded-* entries so it sees the real client IP (rate limiting)
# and the https scheme (email links). Defaults to 1 when DB_TYPE=mysql (single
# nginx) and 0 otherwise. Set to 2 if a CDN (e.g. Cloudflare) sits in front of
# nginx. Keep at 0 when there is NO proxy — a higher value lets clients spoof
# their IP via a forged X-Forwarded-For header.
# TRUSTED_PROXY_COUNT=1

# MySQL (production)
MYSQL_HOST=your-host.mysql.pythonanywhere-services.com
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=your-database-name

# Email — Mailgun
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=mail.yourdomain.com
MAILGUN_REGION=eu
SENDER_EMAIL=noreply@mail.yourdomain.com
SENDER_NAME=YourAppName

# Email — SMTP (backup, optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=True
# SMTP_USE_SSL=False
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Verification
TOKEN_EXPIRY_HOURS=48
UNVERIFIED_CLEANUP_DAYS=14
MAX_VERIFICATION_EMAILS_PER_DAY=3

# Off-site backup (Backblaze B2)
B2_KEY_ID=              # Application key ID from B2 console
B2_APPLICATION_KEY=     # Application key from B2 console
B2_BUCKET_NAME=         # Bucket name
OFFSITE_KEEP_COUNT=14   # Number of remote backups to retain
SLACK_WEBHOOK_URL=      # Optional: Slack Incoming Webhook URL for failure alerts
