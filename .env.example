# Flask
SECRET_KEY=your-secret-key-here

# Database
DB_TYPE=sqlite
SQLITE_PATH=./dummy.db

# MySQL (production)
MYSQL_HOST=your-host.mysql.pythonanywhere-services.com
MYSQL_USER=your-username
MYSQL_PASSWORD=your-password-here
MYSQL_DATABASE=your-database-name

# Email — Mailgun
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=mail.yourdomain.com
MAILGUN_REGION=eu
SENDER_EMAIL=noreply@mail.yourdomain.com
SENDER_NAME=YourAppName

# Email — SMTP (backup, optional)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=True
# SMTP_USE_SSL=False
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# Verification
TOKEN_EXPIRY_HOURS=48
UNVERIFIED_CLEANUP_DAYS=14
MAX_VERIFICATION_EMAILS_PER_DAY=3

# Off-site backup (offsite_backup.py)
HOME_BACKUP_HOST=         # IP or dynamic DNS hostname of home server
HOME_BACKUP_USER=         # SSH username on home server
HOME_BACKUP_PATH=         # Absolute path to backup dir, e.g. /home/youruser/turnushjelper-backups
HOME_BACKUP_SSH_KEY=      # Path to SSH private key on PythonAnywhere, e.g. /home/solveottooren/.ssh/backup_key
HOME_BACKUP_PORT=3125     # SSH port forwarded on your router
OFFSITE_KEEP_COUNT=14     # Number of remote backups to retain
SLACK_WEBHOOK_URL=        # Optional: Slack Incoming Webhook URL for failure alerts

# DigitalOcean warm standby (second destination in offsite_backup.py)
DO_BACKUP_HOST=         # Public IP of DO Droplet
DO_BACKUP_USER=         # SSH user on DO (e.g. deploy)
DO_BACKUP_PATH=         # Absolute path on DO, e.g. /home/deploy/backups
DO_BACKUP_SSH_KEY=      # SSH private key on PythonAnywhere, e.g. /home/solveottooren/.ssh/do_backup_key
DO_BACKUP_PORT=22       # SSH port on DO (default 22)

# Hetzner DB sync — PA → Hetzner (hetzner_db_sync.py, runs on PythonAnywhere)
HETZNER_HOST=           # Public IP of Hetzner server
HETZNER_USER=deploy     # SSH user on Hetzner
HETZNER_BACKUP_PATH=    # Absolute path for dumps on Hetzner, e.g. /home/deploy/backups
HETZNER_SSH_KEY=        # SSH private key on PA, e.g. /home/solveottooren/.ssh/hetzner_sync_key
HETZNER_PORT=22
HETZNER_KEEP_COUNT=7

# PA DB sync — Hetzner → PA (pa_db_sync.py, runs on Hetzner)
PA_SSH_HOST=ssh.pythonanywhere.com
PA_SSH_USER=            # PythonAnywhere username, e.g. solveottooren
PA_SSH_KEY=             # SSH private key on Hetzner, e.g. /home/deploy/.ssh/pa_sync_key
PA_SSH_PORT=3022
PA_BACKUP_PATH=         # Absolute path for dumps on PA, e.g. /home/solveottooren/hetzner_dumps
PA_KEEP_COUNT=7
